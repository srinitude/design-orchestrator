      "id": "route-product-ui-mobile-onboarding",
      "type": "routing",
      "prompt": "Design a mobile onboarding flow and first dashboard for a habit app for nurses working night shifts. I want a written spec, not generated images.",
      "expected_route_id": "product-ui-design",
      "expected_artifacts": [
        "design-brief",
        "journey-map",
        "visual-direction",
        "screen-or-component-spec",
        "design-system-notes",
        "qa-checklist"
      ],
      "required_phases": [
        "intent",
        "research",
        "journey",
        "visual-direction",
        "artifact-generation",
        "critique"
      ],
      "required_sections": [
        "Reference Notes",
        "Design Brief",
        "Journey Map",
        "Visual Direction",
        "Screen or Component Spec",
        "Design System Notes",
        "Critique",
        "QA Checklist"
      ],
      "fallback_behavior": "continue_with_standalone_fallback",
      "quality_checks": [
        "platform is explicit",
        "research appears before visual direction",
        "accessibility is treated as a hard gate",
        "generic modern-clean language is revised into specific choices"
      ]
    },
    {
